		{"id":"b440a2cafcbe6102","type":"text","text":"User input becomes part of SQL code","x":-2240,"y":-2314,"width":391,"height":50},
		{"id":"3dc2bbfee1d6281b","type":"text","text":"No input validation","x":-1260,"y":-2324,"width":341,"height":62},
