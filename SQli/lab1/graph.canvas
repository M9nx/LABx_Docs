		{"id":"ac8a97cf400b5437","type":"text","text":"Code Explanation","x":-512,"y":-2028,"width":252,"height":52},
		{"id":"ecced971f46048e1","type":"text","text":"Line 18-19: $query = \"SELECT * WHERE category = '$category'\"","x":20,"y":-2028,"width":505,"height":52},
		{"id":"b5d158d0a30b0e5b","type":"text","text":"Gets user input: $_GET['category']","x":-310,"y":-2266,"width":330,"height":50},
		{"id":"2b0f3a914eef6152","type":"text","text":"Puts input directly in SQL query","x":-565,"y":-2480,"width":358,"height":50},
		{"id":"992a68711bcd49ed","type":"text","text":"No validation or checking","x":-812,"y":-2264,"width":244,"height":50},
